# Slack tokens — get these from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Anthropic — get from console.anthropic.com (needed in Phase 3)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Your Slack channel IDs (right-click channel → Copy link → last part of URL)
STANDUP_CHANNEL_ID=C0XXXXXXXXX
GENERAL_CHANNEL_ID=C0XXXXXXXXX
